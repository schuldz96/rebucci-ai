{
  "schema_version": "1.1",
  "source": {
    "run_dir_basename": "primecoaching"
  },
  "components": {
    "button": {
      "font_size": "14px",
      "outline": "none",
      "radius": "4px",
      "padding": "10px",
      "font_weight": "500",
      "bg": "var(--primary-600, #449AFF)",
      "text": "white",
      "cursor": "pointer",
      "opacity": "1",
      "transition": "all 0.2s ease",
      "shadow": "0 2px 8px rgba(0, 0, 0, 0.15)",
      "states": {
        "hover": {
          "opacity": "1",
          "text": "#fff",
          "transform": "scale(1.05)",
          "bg": "rgba(255, 255, 255, 0.12)",
          "shadow": "0 4px 12px rgba(37, 99, 235, 0.15)"
        },
        "disabled": {
          "bg": "var(--error-100, #FEE4E2)",
          "text": "var(--error-500, #F04438)",
          "opacity": ".65"
        },
        "focus": {
          "shadow": "none",
          "outline": "0"
        },
        "active": {
          "transform": "translateY(0) scale(0.98)"
        }
      }
    },
    "card": {
      "bg": "white",
      "transform": "translate(-50%, -50%)",
      "font_weight": "600",
      "text": "var(--common-color1, rgb(255, 255, 255))",
      "cursor": "pointer",
      "font_size": "10px",
      "shadow": "0 0 1px var(--common-color0-90, rgba(0, 0, 0, 0.9))",
      "opacity": "1"
    },
    "input": {
      "padding": "8px",
      "font_size": "100%",
      "radius": "6px",
      "outline": "none",
      "shadow": "inset 0 1px 1px rgba(0, 0, 0, .06), 0 0 0 3px rgba(0, 0, 0, 0)",
      "font_weight": "inherit",
      "bg": "transparent",
      "text": "#667085",
      "opacity": "1",
      "cursor": "pointer",
      "transition": "border-color .1s, box-shadow .1s",
      "states": {
        "focus": {
          "shadow": "var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow, 0 0 #0000)",
          "outline": "none"
        },
        "checked": {
          "bg": "var(--primary-700, #3D96FF)"
        },
        "disabled": {
          "bg": "#f2f4f7"
        }
      }
    },
    "badge": {
      "font_weight": "600",
      "font_size": "12px",
      "bg": "rgba(34, 197, 94, 0.1)",
      "text": "#16a34a"
    },
    "link": {
      "padding": "0 10px",
      "font_weight": "600",
      "font_size": "14px",
      "radius": "4px",
      "bg": "var(--primary-200, #B7D8FF)",
      "cursor": "pointer",
      "transition": "all 0.2s ease",
      "shadow": "0 2px 8px rgba(0, 0, 0, 0.15)",
      "states": {
        "hover": {
          "text": "var(--second-color-80, rgba(137, 192, 232, 0.80))",
          "bg": "rgba(255, 255, 255, 0.12)"
        }
      }
    },
    "nav": {
      "text": "var(--common-color1-90, rgba(255, 255, 255, 0.9))",
      "cursor": "pointer",
      "font_size": "16px",
      "padding": "8px 16px 12px 16px",
      "shadow": "0 -4px 20px rgba(0, 0, 0, 0.08)"
    },
    "tab": {
      "text": "#344054",
      "font_weight": "500",
      "font_size": "11px",
      "bg": "white",
      "radius": "8px",
      "cursor": "default",
      "padding": "15px",
      "opacity": "1",
      "variants": {
        "negative": {
          "text": "var(--financeiro-negativo, #F04438)"
        }
      }
    },
    "alert": {
      "font_size": "13px",
      "text": "#64748b",
      "padding": "16px",
      "bg": "white",
      "radius": "8px"
    },
    "table": {
      "bg": "var(--primary-50, #F5FAFF)",
      "cursor": "default",
      "padding": "10px",
      "font_weight": "500",
      "font_size": "13px",
      "text": "var(--gray-400, #98A2B3)",
      "radius": "4px",
      "shadow": "var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), var(--tw-shadow, 0 0 #0000)",
      "opacity": "0.7",
      "transition": "0.25s all",
      "states": {
        "hover": {
          "cursor": "default",
          "bg": "#f5f5f5"
        }
      }
    },
    "tooltip": {
      "cursor": "pointer",
      "radius": "4px",
      "bg": "white",
      "padding": "0 5px",
      "font_weight": "bold",
      "text": "#999",
      "outline": "0",
      "shadow": "0 2px 6px rgba(0, 0, 0, .15)",
      "font_size": "1.1em",
      "opacity": ".65",
      "states": {
        "hover": {
          "text": "#333"
        }
      }
    },
    "modal": {
      "bg": "#3D96FF",
      "transform": "translate(-50%, -50%)",
      "font_weight": "500",
      "font_size": "1em",
      "text": "white",
      "cursor": "default",
      "opacity": ".5",
      "shadow": "0 0 1px rgba(0, 0, 0, .075), 0 1px 2px rgba(0, 0, 0, .075), 1px 2px 4px rgba(0, 0, 0, .075), 1px 3px 8px rgba(0, 0, 0, .075), 2px 4px 16px rgba(0, 0, 0, .075)",
      "states": {
        "hover": {
          "bg": "#3D96FF",
          "text": "white"
        },
        "focus": {
          "bg": "#3D96FF",
          "text": "white",
          "shadow": "0 0 0 3px rgba(61, 150, 255, 0.25)"
        }
      },
      "variants": {
        "fullscreen-popup": {
          "padding": "var(--iti-mobile-popup-margin, 30px)",
          "bg": "rgba(0, 0, 0, 0.5)"
        }
      }
    },
    "avatar": {
      "radius": "100%",
      "cursor": "pointer",
      "shadow": "0px 0px 1px rgba(0, 0, 0, 0.25)",
      "font_weight": "600",
      "font_size": "14px",
      "text": "white",
      "bg": "#cbd5e1",
      "variants": {
        "initials-lg": {
          "font_weight": "600",
          "font_size": "18px",
          "text": "white"
        },
        "initials-chat": {
          "radius": "100%",
          "font_weight": "600",
          "font_size": "14px",
          "text": "white"
        }
      }
    },
    "label": {
      "font_weight": "500",
      "text": "#344054",
      "font_size": "11px",
      "opacity": "0.7"
    }
  },
  "shadow": {
    "xs": "1px 1px 1px rgb(0, 0, 0, 0.1)",
    "sm": "0 0 1px var(--common-color0-90)",
    "md": "0 0 5px var(--common-color0-10)",
    "lg": "0 2px 8px rgba(0, 0, 0, 0.15)",
