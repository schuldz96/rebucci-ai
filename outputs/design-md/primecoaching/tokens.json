    "text": "#ffffff",
    "text-muted": "#667085",
    "border": "#eaecf0",
    "error": "#f04438",
    "success": "#17b26a",
    "fav-pink": "#ff0083",
    "first-color": "#001f35",
    "primary-navy": "#033961",
    "primary-blue": "#045c9d",
    "warning": "#f79009",
    "teal": "#15b79e"
  },
